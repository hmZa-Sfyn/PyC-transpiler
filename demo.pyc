# demo.pyc — PyC full feature demo including all smalltalk keywords
# Run:  ./pyc run demo.pyc

def add(a: int, b: int) -> int:
    return a + b

def fizzbuzz(n: int) -> str:
    if n % 15 == 0:
        return "FizzBuzz"
    elif n % 3 == 0:
        return "Fizz"
    elif n % 5 == 0:
        return "Buzz"
    else:
        return str(n)

def is_even(n: int) -> bool:
    return n % 2 == 0

def factorial(n: int) -> int:
    if n <= 1:
        return 1
    return n * factorial(n - 1)

struct Point:
    x: float
    y: float

def main():
    print("══════════════════════════════════════")
    print("   PyC — Smalltalk Keywords Demo")
    print("══════════════════════════════════════")

    # ── iftrue / iffalse / unless ─────────────────────────────────────────────
    print("\n[1] iftrue / iffalse / unless")
    x = 10
    iftrue x > 5: print("x is greater than 5")
    iffalse x > 100: print("x is not greater than 100")
    unless x == 0: print("x is non-zero")

    # ── repeat / times ────────────────────────────────────────────────────────
    print("\n[2] repeat / times")
    repeat 3: print("hello from repeat!")
    times 2: print("hello from times!")

    # ── each ──────────────────────────────────────────────────────────────────
    print("\n[3] each")
    nums: list[int] = [10, 20, 30, 40, 50]
    each n in nums: print(n)

    each i in range(5): print(f"  i={i}")

    # ── loop / forever ────────────────────────────────────────────────────────
    print("\n[4] loop (infinite with break)")
    counter = 0
    loop:
        counter += 1
        iftrue counter >= 3: done

    print(f"loop ran {counter} times")

    forever:
        counter -= 1
        iftrue counter <= 0: done

    print(f"forever ran down to {counter}")

    # ── until ─────────────────────────────────────────────────────────────────
    print("\n[5] until")
    n = 0
    until n >= 5:
        n += 1
    print(f"until stopped at n={n}")

    # ── done / skip ───────────────────────────────────────────────────────────
    print("\n[6] done and skip (aliases for break/continue)")
    for i in range(10):
        iftrue i == 3: skip
        iftrue i == 7: done
        print(f"  i={i}")

    # ── ret / give ────────────────────────────────────────────────────────────
    print("\n[7] ret and give (aliases for return)")
    result = add(3, 4)
    print(f"add(3,4) = {result}")

    # ── swap ──────────────────────────────────────────────────────────────────
    print("\n[8] swap")
    a = 100
    b = 200
    print(f"before: a={a} b={b}")
    swap a, b
    print(f"after:  a={a} b={b}")

    # ── default ───────────────────────────────────────────────────────────────
    print("\n[9] default (set if zero/null)")
    score = 0
    default score = 42
    print(f"score after default = {score}")

    score2 = 99
    default score2 = 0
    print(f"score2 (already set) = {score2}")

    # ── check ─────────────────────────────────────────────────────────────────
    print("\n[10] check (assert)")
    check 2 + 2 == 4
    check result == 7
    print("all checks passed!")

    # ── die ───────────────────────────────────────────────────────────────────
    print("\n[11] die (would exit — skipping live demo)")
    # die "something went wrong"   # uncomment to test

    # ── maybe ─────────────────────────────────────────────────────────────────
    print("\n[12] maybe (safe call, ignore null)")
    name = "PyC"
    maybe name.upper()
    print("maybe executed safely")

    # ── print! ────────────────────────────────────────────────────────────────
    print("\n[13] print! (no-paren println)")
    print! "Hello from print!"
    print! "a=", a, "b=", b

    # ── clamp ─────────────────────────────────────────────────────────────────
    print("\n[14] clamp")
    v1 = clamp(150, 0, 100)
    v2 = clamp(-5, 0, 100)
    v3 = clamp(50, 0, 100)
    print(f"clamp(150,0,100) = {v1}")
    print(f"clamp(-5, 0,100) = {v2}")
    print(f"clamp(50, 0,100) = {v3}")

    # ── between ───────────────────────────────────────────────────────────────
    print("\n[15] between")
    print(f"between(50,0,100)  = {between(50, 0, 100)}")
    print(f"between(150,0,100) = {between(150, 0, 100)}")

    # ── either ────────────────────────────────────────────────────────────────
    print("\n[16] either ... or ... (null coalescing)")
    fallback = either 0 or 99
    print(f"either 0 or 99 = {fallback}")
    fallback2 = either 42 or 99
    print(f"either 42 or 99 = {fallback2}")

    # ── fizzbuzz with ret ─────────────────────────────────────────────────────
    print("\n[17] FizzBuzz 1-15:")
    for i in range(1, 16):
        print(f"  {fizzbuzz(i)}")

    # ── factorial ─────────────────────────────────────────────────────────────
    print(f"\nfactorial(10) = {factorial(10)}")

    print("\n══════════════════════════════════════")
    print("           All done!")
    print("══════════════════════════════════════")
